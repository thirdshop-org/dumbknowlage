# ArangoDB
ARANGO_ROOT_PASSWORD=change_me
ARANGO_DATABASE=whisper_nlp_graph

# Ollama (embeddings — même serveur que le container)
OLLAMA_BASE_URL=http://192.168.1.1:11434

# Whisper (CPU: float32, GPU: float16)
WHISPER_MODEL=turbo
COMPUTE_TYPE=float32

# API
API_PORT=8000
API_DOMAIN=notes-graph.domain.fr

# Data persistence (bind mount root — pour Dokploy)
DATA_ROOT=${PWD}/.data

# Traefik (optionnel)
TRAEFIK_ENABLE=true
TRAEFIK_NETWORK=dokploy-network
